{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "ChillestOrange"
  ],
  "contact": {
    "homepage": "https://github.com/chillestorange/worldsync",
    "sources": "https://github.com/chillestorange/worldsync",
    "issues": "https://github.com/chillestorange/worldsync/issues"
  },
  "license": "${mod_license}",
  "icon": "assets/worldsync/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "io.github.chillestorange.fabric.WorldSyncClientFabric"
    ],
    "modmenu": [
      "io.github.chillestorange.fabric.integration.ModMenuIntegration"
    ]
  },
  "suggests": {
    "modmenu": "*"
  },
  "mixins": [
    "worldsync.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=25",
